{
  "manifest_version": 2,
  "name": "CAPTCHA Diary",
  "version": "0.2",
  "description": "Persistent in-browser CAPTCHA archive: auto-captures images, cursor traces, and DOM data across visited tabs.",

  "browser_specific_settings": {
    "gecko": {
      "id": "captcha-diary@localhost",
      "strict_min_version": "109.0"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png"
  },

  "permissions": [
    "activeTab",
    "<all_urls>",
    "webRequest",
    "webRequestBlocking",
    "storage",
    "tabs",
    "downloads"
  ],

  "background": {
    "scripts": ["db.js", "background.js","jszip.min.js"],
    "persistent": true
  },

  "browser_action": {
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    },
    "default_title": "CAPTCHA Diary",
    "default_popup": "panel.html"
  },

  "sidebar_action": {
    "default_panel": "sidebar.html",
    "default_title": "CAPTCHA Archive",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["main.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    "icons/dot-gray.png",
    "icons/dot-red.png"
  ]
}
